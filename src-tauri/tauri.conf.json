{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexus Vault Sync",
  "version": "0.4.34",
  "identifier": "com.lattice.vault-sync",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Pair with Nexus",
        "width": 580,
        "height": 900,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "nsis", "dmg", "appimage"],
    "macOS": {
      "exceptionDomain": "",
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJDNkJBQTNCMUUwQTBFNjgKUldSb0Rnb2VPNnBydkZQbkoycm1UcXpzZ2hwNk02a245SGxZN3F6cENXdExMakU2RTZCc3htMUcK",
      "endpoints": [
        "https://nexus.obsidian-inc.com/admin/api/vault-sync/releases/{{target}}-{{arch}}/latest"
      ],
      "dialog": false
    }
  }
}
